# Copy to .env and adjust as needed (`.env` is gitignored).
# Start Postgres: make db   (or POSTGRES_HOST_PORT=5433 make db if 5432 is busy)

# DATABASE_URL=postgres://openoutreach:openoutreach@localhost:5432/openoutreach
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openoutreach
POSTGRES_USER=openoutreach
POSTGRES_PASSWORD=openoutreach

# USE_SQLITE=1
